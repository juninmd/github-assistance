# Example .env file for local development
# NEVER commit this file to Git!

# =============================================================================
# Required
# =============================================================================

# GitHub Personal Access Token
# Get it from: https://github.com/settings/tokens
# Required scopes: repo, workflow
GITHUB_TOKEN=ghp_your_token_here

# Jules API Key (for AI agent orchestration)
# Get it from Jules dashboard
JULES_API_KEY=<your_jules_key_here>

# =============================================================================
# AI Provider (choose one)
# =============================================================================

# Enable AI features (true/false)
ENABLE_AI=false

# AI Provider: "gemini", "openai", or "ollama"
AI_PROVIDER=ollama

# AI Model override (default depends on provider):
#   gemini: gemini-2.5-flash
#   openai: gpt-4o
#   ollama: qwen3:1.7b
AI_MODEL=

# Gemini API Key (required if AI_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_key_here

# OpenAI API Key (required if AI_PROVIDER=openai)
OPENAI_API_KEY=sk-your_key_here

# Ollama base URL (used if AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_HOST=http://ollama.ai.svc.cluster.local:11434

# =============================================================================
# GitHub Configuration
# =============================================================================

# GitHub owner/organization to monitor
GITHUB_OWNER=juninmd

# Repository allowlist path
REPOSITORY_ALLOWLIST_PATH=config/repositories.json

# =============================================================================
# Notifications
# =============================================================================

# Telegram bot token and chat ID (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# =============================================================================
# Agent Toggles (true/false)
# =============================================================================

PM_AGENT_ENABLED=true
UI_AGENT_ENABLED=true
DEV_AGENT_ENABLED=true
PR_ASSISTANT_ENABLED=true
SECURITY_SCANNER_ENABLED=true
SECRET_REMOVER_ENABLED=true
CI_HEALTH_ENABLED=true
PR_SLA_ENABLED=true
JULES_TRACKER_ENABLED=true
PROJECT_CREATOR_ENABLED=true
BRANCH_CLEANER_ENABLED=true
INTELLIGENCE_AGENT_ENABLED=true

# =============================================================================
# Jules Execution Tuning
# =============================================================================

JULES_DAILY_SESSION_LIMIT=100
JULES_BURST_MAX_ACTIONS=20
JULES_BURST_TRIGGER_HOUR_UTC_MINUS_3=18

# =============================================================================
# opencode Execution Tuning (seconds)
# =============================================================================

OPENCODE_MODELS_TIMEOUT_SECONDS=20
OPENCODE_CLONE_TIMEOUT_SECONDS=120
OPENCODE_WARMUP_TIMEOUT_SECONDS=180
OPENCODE_RUN_TIMEOUT_SECONDS=1200
OPENCODE_PUSH_TIMEOUT_SECONDS=120
OPENCODE_RUN_MAX_ATTEMPTS=2

# =============================================================================
# General
# =============================================================================

# Debug mode
DEBUG=false

# Agent run interval (hours)
AGENT_RUN_INTERVAL_HOURS=24
