# Example .env file for local development
# NEVER commit this file to Git!

# ── Required ──────────────────────────────────────────────────────────────

# GitHub Personal Access Token (scopes: repo, workflow)
GITHUB_TOKEN=ghp_your_token_here

# Jules API Key (get from Jules dashboard)
JULES_API_KEY=your_jules_key_here

# ── AI Providers (at least one required for AI-powered agents) ────────────

# Gemini API Key (from https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_key_here

# OpenAI API Key (if using OpenAI provider)
OPENAI_API_KEY=

# LiteLLM API Key (if using LiteLLM provider)
LITELLM_API_KEY=

# LiteLLM API base URL (K8s internal default; override for local dev)
# LITELLM_API_BASE=http://localhost:4000

# Ollama base URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Ollama timeout in milliseconds (default: 300)
OLLAMA_TIMEOUT_MS=300000

# OpenAI base URL (default: https://api.openai.com/v1)
# OPENAI_BASE_URL=https://api.openai.com/v1

# AI enablement and model selection
ENABLE_AI=false
AI_PROVIDER=ollama
AI_MODEL=qwen3:1.7b

# ── GitHub Configuration ─────────────────────────────────────────────────

# GitHub owner/organization to monitor
GITHUB_OWNER=juninmd

# Fallback token for clone operations (GH_PAT is used if GITHUB_TOKEN is unavailable)
GH_PAT=

# Repository allowlist path
REPOSITORY_ALLOWLIST_PATH=config/repositories.json

# ── Telegram Notifications ───────────────────────────────────────────────

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Agent Toggles (true/false) ───────────────────────────────────────────

ENABLE_PRODUCT_MANAGER=true     # PM_AGENT_ENABLED
ENABLE_INTERFACE_DEVELOPER=true # UI_AGENT_ENABLED
ENABLE_SENIOR_DEVELOPER=true    # DEV_AGENT_ENABLED
ENABLE_PR_ASSISTANT=true        # PR_ASSISTANT_ENABLED
ENABLE_SECURITY_SCANNER=true    # SECURITY_SCANNER_ENABLED
ENABLE_CI_HEALTH=true           # CI_HEALTH_ENABLED
ENABLE_PR_SLA=true              # PR_SLA_ENABLED
ENABLE_JULES_TRACKER=true       # JULES_TRACKER_ENABLED
ENABLE_SECRET_REMOVER=true      # SECRET_REMOVER_ENABLED
ENABLE_PROJECT_CREATOR=true     # PROJECT_CREATOR_ENABLED
ENABLE_BRANCH_CLEANER=true      # BRANCH_CLEANER_ENABLED
ENABLE_INTELLIGENCE_STANDARDIZER=true  # INTELLIGENCE_AGENT_ENABLED
ENABLE_README_CURATOR=true      # README_CURATOR_ENABLED
ENABLE_CODE_REVIEWER=true       # CODE_REVIEWER_ENABLED

# ── Senior Developer Agent ───────────────────────────────────────────────

# Enable burst mode (uses Jules sessions for high-impact tasks)
SENIOR_DEVELOPER_ENABLE_BURST=true
# Daily repository analysis limit
SENIOR_DEVELOPER_DAILY_REPO_LIMIT=5

# ── Jules Client Tuning ──────────────────────────────────────────────────

JULES_TIMEOUT_SECONDS=1800
JULES_WAIT_SECONDS=14400
JULES_RETRY_ATTEMPTS=5
JULES_BURST_MAX_ACTIONS=3
JULES_BURST_TRIGGER_HOUR_UTC_MINUS_3=2
JULES_DAILY_SESSION_LIMIT=10

# ── PR Assistant / Conflict Resolver ─────────────────────────────────────

CONFLICT_AI_PROVIDER=gemini
CONFLICT_AI_MODEL=gemini-2.5-flash
CONFLICT_AI_FALLBACK_ENABLED=true
PIPELINE_FIX_ENABLED=true
PIPELINE_FIX_MAX_ATTEMPTS=3

# ── Secret Remover ───────────────────────────────────────────────────────

SECRET_REMOVER_AI_PROVIDER=gemini
SECRET_REMOVER_AI_MODEL=gemini-2.5-flash
RESULTS_DIR=results

# ── Webhook Server (GitHub App) ──────────────────────────────────────────

GITHUB_APP_ID=
GITHUB_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=
WEBHOOK_DATABASE_PATH=data/webhooks.db
AUTOMATION_MODE=observe

# ── Scheduling ───────────────────────────────────────────────────────────

AGENT_RUN_INTERVAL_HOURS=24

# ── opencode Execution Tuning (seconds) ──────────────────────────────────

OPENCODE_MODELS_TIMEOUT_SECONDS=20
OPENCODE_CLONE_TIMEOUT_SECONDS=120
OPENCODE_WARMUP_TIMEOUT_SECONDS=180
OPENCODE_RUN_TIMEOUT_SECONDS=1200
OPENCODE_PUSH_TIMEOUT_SECONDS=120
OPENCODE_RUN_MAX_ATTEMPTS=2

# ── Misc ─────────────────────────────────────────────────────────────────

NO_COLOR=true
DEBUG=false
